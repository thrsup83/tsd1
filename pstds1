$searchName = "YYYYY Agent"
$uninstallPath = "SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall"

$machineKey = [Microsoft.Win32.RegistryKey]::OpenBaseKey([Microsoft.Win32.RegistryHive]::LocalMachine, [Microsoft.Win32.RegistryView]::Registry64)
$apps = $machineKey.OpenSubKey($uninstallPath)

$found = $false

foreach ($subKeyName in $apps.GetSubKeyNames()) {
    $subKey = $apps.OpenSubKey($subKeyName)
    $displayName = $subKey.GetValue("DisplayName")
    
    if ($displayName -like "*$searchName*") {
        $version = $subKey.GetValue("DisplayVersion")
        Write-Output "OK - $version"
        $found = $true
        break
    }
}

if (-not $found) {
    Write-Output "fail - Nao encontrado no Painel de Controle"
}

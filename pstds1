$LogPath = "C:\Windows\Temp\log1.txt"

function Write-Log {
    param ([string]$Message)
    $DateTime = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $LogLine = "[$DateTime] $Message"
    Add-Content -Path $LogPath -Value $LogLine
    Write-Host $LogLine
}

Write-Log "Starting FireEye/Trellix brute-force cleanup process..."

# Pega o diretório atual onde este script está rodando
$CurrentDir = $PSScriptRoot
if ([string]::IsNullOrEmpty($CurrentDir)) { $CurrentDir = "." }

$CleanupToolPath = Join-Path -Path $CurrentDir -ChildPath "FireEyeAgentCleanupTool.exe"

# Verifica se a ferramenta de limpeza está na mesma pasta
if (-not (Test-Path -Path $CleanupToolPath)) {
    Write-Log "CRITICAL ERROR: FireEyeAgentCleanupTool.exe not found in the script directory."
    Write-Host "Cleanup tool not found. Please place the script in the same folder as the .exe" -ForegroundColor Red
    return
}

try {
    Write-Log "Executing Cleanup Tool: $CleanupToolPath /Cleanup"
    
    # Roda a ferramenta de limpeza. O parâmetro /Cleanup é o padrão da fabricante para forçar a remoção.
    $Arguments = "/Cleanup"
    
    # O -Wait garante que o PowerShell só avance quando a ferramenta terminar totalmente o serviço
    $Process = Start-Process -FilePath $CleanupToolPath -ArgumentList $Arguments -Wait -NoNewWindow -PassThru
    
    Write-Log "Cleanup Tool finished. Exit code: $($Process.ExitCode)"
    
    if ($Process.ExitCode -eq 0 -or $Process.ExitCode -eq 3010) {
        Write-Host "Force cleanup completed successfully!" -ForegroundColor Green
        if ($Process.ExitCode -eq 3010) {
            Write-Log "Warning: A reboot is highly recommended after a force cleanup."
        }
    } else {
        Write-Host "Cleanup finished with abnormal code: $($Process.ExitCode). Check the system." -ForegroundColor Yellow
    }

} catch {
    Write-Log "CRITICAL ERROR: Failed to start Cleanup Tool. Details: $_"
}

Write-Log "Script finished."

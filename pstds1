# Configuration
$TargetServer = "XXX"
$RemoteFile   = "D:\tst\tst1.txt"

# 1. Open session
$Session = New-PSSession -ComputerName $TargetServer

# 2. Set Read-Only permissions for Authenticated Users
Invoke-Command -Session $Session -ScriptBlock {
    param($RemoteFile)
    
    $Parent = Split-Path $RemoteFile
    $FileName = Split-Path $RemoteFile -Leaf
    
    Push-Location $Parent
    
    # Disable inheritance and copy current permissions
    & icacls $FileName /inheritance:d
    
    # Grant only Read and Execute (RX) to Authenticated Users
    # :r replaces any existing permissions for this specific group
    & icacls $FileName /grant:r "Authenticated Users":RX
    
    Pop-Location
} -ArgumentList $RemoteFile

# 3. Close session
Remove-PSSession $Session

Write-Host "Success: Permissions set to Read-Only (RX) for $RemoteFile" -ForegroundColor Green

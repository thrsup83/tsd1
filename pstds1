$RegistryPaths = @(
    "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\*",
    "HKLM:\SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\*"
)

$App = Get-ItemProperty $RegistryPaths -ErrorAction SilentlyContinue | Where-Object { 
    $_.DisplayName -match "FireEye" -or $_.DisplayName -match "Trellix"
}

if ($App) {
    # Captura a versão. Caso encontre mais de um componente, usa o primeiro.
    $Version = $App[0].DisplayVersion
    Write-Host "installed-$Version"
} else {
    Write-Host "not instaled"
}

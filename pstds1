$Password = "XXXX" 
$LogPath = "C:\Windows\Temp\log1.txt"

function Write-Log {
    param ([string]$Message)
    $DateTime = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $LogLine = "[$DateTime] $Message"
    Add-Content -Path $LogPath -Value $LogLine
    Write-Host $LogLine
}

Write-Log "Starting pure PowerShell Trellix/FireEye uninstallation process..."

# Varre o Registro (32 e 64 bits) para encontrar a instalação nativa do FireEye
$RegistryPaths = @(
    "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\*",
    "HKLM:\SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\*"
)

$FireEyeApp = Get-ItemProperty $RegistryPaths -ErrorAction SilentlyContinue | Where-Object { 
    $_.DisplayName -match "FireEye Endpoint Agent" -or $_.DisplayName -match "Trellix Endpoint Agent"
}

if (-not $FireEyeApp) {
    Write-Log "CRITICAL ERROR: FireEye/Trellix installation not found in the Windows Registry."
    Write-Host "Scan failed. Product not found." -ForegroundColor Red
    return
}

# Extrai o ID (GUID) exato da instalação no seu sistema
$ProductGUID = $FireEyeApp[0].PSChildName
Write-Log "Success: Product found in registry. GUID: $ProductGUID"

# Monta o comando perfeito para o msiexec (nativo do Windows) não dar o erro 1360
$Arguments = "/x `"$ProductGUID`" /qn /norestart UNINSTALL_PASSWORD=`"$Password`""

try {
    Write-Log "Executing MSI uninstallation command..."
    
    $Process = Start-Process -FilePath "msiexec.exe" -ArgumentList $Arguments -Wait -NoNewWindow -PassThru
    
    if ($Process.ExitCode -eq 0 -or $Process.ExitCode -eq 3010) {
        Write-Log "Uninstallation completed successfully. Exit code: $($Process.ExitCode)"
        Write-Host "Uninstallation completed!" -ForegroundColor Green
    } else {
        Write-Log "Uninstallation failed. The installer returned error code: $($Process.ExitCode)"
        Write-Host "Uninstallation error. Code: $($Process.ExitCode)" -ForegroundColor Red
    }

} catch {
    Write-Log "CRITICAL ERROR: Failed to start msiexec. Details: $_"
}

Write-Log "Script finished."

$targetServer = "XXX"
$remotePath   = "D:\tst\tst1.txt"

$session = New-PSSession -ComputerName $targetServer

Invoke-Command -Session $session -ScriptBlock {
    param($path)

    $dir  = Split-Path $path
    $file = Split-Path $path -Leaf

    Set-Location $dir

    # Disable inheritance and convert to explicit
    icacls $file /inheritance:d

    # Grant Read & Execute (RX) using SID to avoid naming issues
    icacls $file /grant:r "*S-1-5-11:RX"

} -ArgumentList $remotePath

Remove-PSSession $session

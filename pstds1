$Password = "XXXX"
$LogPath = "C:\Windows\Temp\log1.txt"
$SetupFolder = "C:\temp\fe"

function Write-Log {
    param ([string]$Message)
    $DateTime = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $LogLine = "[$DateTime] $Message"
    Add-Content -Path $LogPath -Value $LogLine
    Write-Host $LogLine
}

Write-Log "Starting uninstallation using the setup file in $SetupFolder..."

$InstallerFile = Get-ChildItem -Path $SetupFolder -Filter "xagtSetup*.msi" -ErrorAction SilentlyContinue | Select-Object -First 1

if (-not $InstallerFile) {
    Write-Log "CRITICAL ERROR: xagtSetup MSI file not found in $SetupFolder."
    Write-Host "File not found. Check the log." -ForegroundColor Red
    return
}

$Arguments = "/x `"$($InstallerFile.FullName)`" /qn /norestart UNINSTALL_PASSWORD=`"$Password`""

try {
    Write-Log "Executing command: msiexec.exe $Arguments"
    
    $Process = Start-Process -FilePath "msiexec.exe" -ArgumentList $Arguments -Wait -NoNewWindow -PassThru
    
    if ($Process.ExitCode -eq 0 -or $Process.ExitCode -eq 3010) {
        Write-Log "Uninstallation completed successfully. Exit code: $($Process.ExitCode)"
        Write-Host "Uninstallation completed!" -ForegroundColor Green
    } else {
        Write-Log "Uninstallation failed. Exit code: $($Process.ExitCode)"
        Write-Host "Uninstallation error. Code: $($Process.ExitCode)" -ForegroundColor Red
    }

} catch {
    Write-Log "CRITICAL ERROR: Failed to start the process. Details: $_"
}

Write-Log "Script finished."

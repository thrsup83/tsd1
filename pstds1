# Configuration
$TargetServer = "XXX"
$RemoteFile   = "D:\tst\tst1.txt"
$LocalBkpPath = "C:\temp\chgs\XXX_bkp\ARQUIVO_AQUI.txt"

# 1. Open session
$Session = New-PSSession -ComputerName $TargetServer

# 2. Upload local backup to remote temp
$TempName = Split-Path $LocalBkpPath -Leaf
Copy-Item -Path $LocalBkpPath -Destination "C:\Windows\Temp\$TempName" -ToSession $Session

# 3. Restore permissions
Invoke-Command -Session $Session -ScriptBlock {
    param($RemoteFile, $TempName)
    
    $ParentDir = Split-Path $RemoteFile
    $BkpPath   = "C:\Windows\Temp\$TempName"
    
    # Restore must run from the parent folder
    Push-Location $ParentDir
    & icacls . /restore $BkpPath
    Pop-Location
} -ArgumentList $RemoteFile, $TempName

# 4. Remote cleanup and close session
Invoke-Command -Session $Session -ScriptBlock { 
    param($TempName)
    Remove-Item -Path "C:\Windows\Temp\$TempName" -Force 
} -ArgumentList $TempName

Remove-PSSession $Session

Write-Host "Success: Permissions restored on $TargetServer" -ForegroundColor Green

# change these
$server = "XXX"
$file = "D:\tst\tst1.txt"

# start session
$s = New-PSSession -ComputerName $server

Invoke-Command -Session $s -ScriptBlock {
    param($file)
    
    $path = Split-Path $file
    $name = Split-Path $file -Leaf
    
    # move to folder
    cd $path
    
    # break inheritance and keep perms
    icacls $name /inheritance:d
    
    # set RX only for auth users
    icacls $name /grant:r "Authenticated Users":RX
    
} -ArgumentList $file

# cleanup
Remove-PSSession $s

Write-Host "Done: $file updated on $server" -ForegroundColor Green

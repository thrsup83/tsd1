param(
    [Parameter(Mandatory=$true)]
    [string]$FilePath
)

# 1. Setup local backup environment
$TargetFolder = "C:\temp\chgs\SCCM_Remediation_Bkp"
$Timestamp = Get-Date -Format "yyyyMMdd_HHmm"
$FileName = Split-Path $FilePath -Leaf
$BkpFile = "$($FileName)_ACL_$Timestamp.txt"

if (-not (Test-Path $TargetFolder)) {
    New-Item -Path $TargetFolder -ItemType Directory -Force | Out-Null
}

try {
    if (Test-Path $FilePath) {
        # 2. Backup current permissions locally
        $ParentDir = Split-Path $FilePath
        Push-Location $ParentDir
        & icacls $FileName /save "$TargetFolder\$BkpFile"
        Pop-Location

        # 3. Apply Fix: Disable inheritance and set RX for Authenticated Users
        # Using SID *S-1-5-11 to avoid language/naming issues
        & icacls $FilePath /inheritance:d
        & icacls $FilePath /grant:r "*S-1-5-11:RX"

        Write-Output "SUCCESS: Backup created at $TargetFolder\$BkpFile and permissions updated for $FilePath"
    } else {
        Write-Error "File not found: $FilePath"
    }
}
catch {
    Write-Error "An error occurred: $($_.Exception.Message)"
}

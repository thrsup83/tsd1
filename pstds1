param(
    [Parameter(Mandatory=$true)]
    [string]$FilePath
)


$Server      = $env:COMPUTERNAME
$Timestamp   = Get-Date -Format "yyyyMMdd_HHmm"
$FileName    = Split-Path $FilePath -Leaf

$BaseDir     = "C:\temp\chgs"
$BkpDir      = "$BaseDir\$($Server)_bkp"
$ResolvedDir = "$BaseDir\$($Server)_resolved"
$SuccessLog  = "$BaseDir\SCCM_Remediation_Success.log"


foreach ($Dir in ($BkpDir, $ResolvedDir)) {
    if (-not (Test-Path $Dir)) { New-Item -Path $Dir -ItemType Directory -Force | Out-Null }
}

try {
    if (Test-Path $FilePath) {
        $Parent = Split-Path $FilePath
        $BkpFile = "$($FileName)_ACL_PRE_$Timestamp.txt"
        $ResFile = "$($FileName)_ACL_POST_$Timestamp.txt"

       
        Push-Location $Parent
        & icacls $FileName /save "$BkpDir\$BkpFile"
        Pop-Location

       
        & icacls $FilePath /inheritance:d
        & icacls $FilePath /grant:r "*S-1-5-11:RX"

        
        Push-Location $Parent
        & icacls $FileName /save "$ResolvedDir\$ResFile"
        Pop-Location

        
        $LogEntry = "$(Get-Date -Format "yyyy-MM-dd HH:mm:ss") | $Server | $FilePath | Status: REMEDIATED | Proof: $ResFile"
        $LogEntry | Out-File -FilePath $SuccessLog -Append

        Write-Output "SUCCESS: Remediation complete for $FilePath. Evidence stored in $ResolvedDir"
    }
    else {
        Write-Error "File not found: $FilePath"
    }
}
catch {
    Write-Error "Critical Error on $Server : $($_.Exception.Message)"
}

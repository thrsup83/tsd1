# Script to remove FireEye HX Agent

Write-Host "Searching for installed FireEye HX Agent..."

# Search for FireEye product
$produto = Get-WmiObject -Class Win32_Product | Where-Object {
    $_.Name -like "*FireEye*" -or $_.Name -like "*Trellix*"
}

if ($produto) {
    Write-Host "Product found: $($produto.Name)"
    Write-Host "Starting removal..."

    # If your installation requires a password, enter it here:
    $password = "XXXX"

    # Execute silent uninstall
    # Ajustes: UNINSTALL_PASSWORD, aspas na senha (`" `") e o -Wait.
    $Argumentos = "/x $($produto.IdentifyingNumber) /qn UNINSTALL_PASSWORD=`"$password`" /norestart"
    
    Start-Process "msiexec.exe" -ArgumentList $Argumentos -Wait -NoNewWindow

    Write-Host "Removal completed."
} else {
    Write-Host "No FireEye product found."
}

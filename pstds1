:: 1. Mata qualquer resquício do instalador e do agente antigo
taskkill /F /IM msiexec.exe /T >nul 2>&1
taskkill /F /IM nessus-agent-module.exe /T >nul 2>&1
taskkill /F /IM nessusd.exe /T >nul 2>&1

:: 2. Deleta o serviço que a gente criou "errado"
sc delete "Nessus Agent"

:: 3. Cria o serviço apontando para o Service Wrapper (o jeito certo)
sc create "Nessus Agent" binPath= "C:\Program Files\Tenable\Nessus Agent\nessus-service.exe" start= auto displayname= "Nessus Agent" type= own

:: 4. Tenta subir de novo
net start "Nessus Agent"

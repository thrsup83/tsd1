
param (
    [Parameter(Mandatory=$true, HelpMessage="Enter the uninstall password")]
    [string]$Password
)

$LogPath = "C:\Windows\Temp\log1.txt"

function Write-Log {
    param ([string]$Message)
    $DateTime = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $LogLine = "[$DateTime] $Message"
    Add-Content -Path $LogPath -Value $LogLine
    Write-Host $LogLine
}

Write-Log "Starting Trellix/FireEye uninstallation process..."

$ExecutablePath = "C:\Program Files\FireEye\xagt\xagt.exe"
$Arguments = "-uninstall -password `"$Password`" -quiet -norestart"

try {
    Write-Log "Executing command: $ExecutablePath $Arguments"
    
    $Process = Start-Process -FilePath $ExecutablePath -ArgumentList $Arguments -Wait -NoNewWindow -PassThru
    
    if ($Process.ExitCode -eq 0 -or $Process.ExitCode -eq 3010) {
        Write-Log "Uninstallation completed successfully. Exit code: $($Process.ExitCode)"
        if ($Process.ExitCode -eq 3010) {
            Write-Log "Warning: The system requires a restart to complete the removal (reboot suppressed by script)."
        }
    } else {
        Write-Log "Uninstallation failed. The installer returned error code: $($Process.ExitCode)"
    }

} catch {
    Write-Log "CRITICAL ERROR: Failed to execute the uninstallation process. Details: $_"
}

Write-Log "Script finished."

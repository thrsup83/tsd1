$regPath = "HKLM:\SOFTWARE\YYYYY Labs\YYYYYAgent"

if (Test-Path $regPath) {
    $item = Get-ItemProperty -Path $regPath -ErrorAction SilentlyContinue
    $version = $item.Version
    
    if ($version) {
        Write-Output "OK - $version"
    } else {
        Write-Output "fail - Valor 'Version' nao encontrado na chave"
        # Lista o que o PS está enxergando na chave para conferir o nome correto:
        $item | Select-Object * -ExcludeProperty PSPath,PSParentPath,PSChildName,PSDrive,PSProvider
    }
} else {
    Write-Output "fail - Caminho do registro nao encontrado"
}

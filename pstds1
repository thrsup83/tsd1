Write-Host "--- Active Management Point ---" -ForegroundColor Cyan
Get-WmiObject -Namespace "root\ccm\LocationServices" -Class "SMS_ActiveManagementPoint" | Select-Object Name, Type

Write-Host "`n--- Boundary and Site Discovery ---" -ForegroundColor Cyan
$log = "C:\Windows\CCM\Logs\LocationServices.log"
if (Test-Path $log) {
    Get-Content $log -Tail 100 | Select-String "LSGetManagementPointsForSite|Boundary|AD site" | Select-Object -Last 5
}

Write-Host "`n--- AD Domain Info ---" -ForegroundColor Cyan
[System.DirectoryServices.ActiveDirectory.ActiveDirectorySite]::GetComputerSite() | Select-Object Name

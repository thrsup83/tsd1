$Path = "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\Memory Management"
$RegistryValues = @{
    "FeatureSettingsOverride"     = 0x00800048
    "FeatureSettingsOverrideMask" = 0x00000003
}

# Loop through the table to apply settings
foreach ($Name in $RegistryValues.Keys) {
    Set-ItemProperty -Path $Path -Name $Name -Value $RegistryValues[$Name] -PropertyType DWord -Force
}




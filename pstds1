$serverList = Get-Content "z:\THS\SO_1\SO_1_Servers.txt"
$sourceFile = "z:\THS\SO_1\YYYYYOne.msi"
$destDir = "temp\SO_Inst1"

foreach ($server in $serverList) {
    if (Test-Connection -ComputerName $server -Count 1 -Quiet) {
        try {
            $remoteFolder = "\\$server\C$\$destDir"
            $remoteFile = Join-Path $remoteFolder "YYYYYOne.msi"

            # 1. Create directory if missing
            if (-not (Test-Path $remoteFolder)) {
                New-Item -Path $remoteFolder -ItemType Directory -Force | Out-Null
            }

            # 2. Check if file already exists
            if (Test-Path $remoteFile) {
                Write-Output "SKIP: $server - File already exists"
            } else {
                # 3. Copy file
                Copy-Item -Path $sourceFile -Destination $remoteFolder -Force -ErrorAction Stop
                
                # 4. Final verification
                if (Test-Path $remoteFile) {
                    Write-Output "SUCCESS: $server - File copied"
                } else {
                    Write-Output "FAILED: $server - Verification failed after copy"
                }
            }
        }
        catch {
            Write-Output "ERROR: $server - $($_.Exception.Message)"
        }
    } else {
        Write-Output "OFFLINE: $server"
    }
}

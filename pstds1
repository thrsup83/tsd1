$serverList = Get-Content "z:\THS\SO_1\SO_1_Servers.txt"
$sourceFile = "z:\THS\SO_1\YYYYYOne.msi"
$destinationFolder = "temp\YYYYY_installer"

foreach ($server in $serverList) {
    $targetPath = "\\$server\C$\$destinationFolder"
    
    try {
        if (-not (Test-Path $targetPath)) {
            New-Item -Path $targetPath -ItemType Directory -Force | Out-Null
        }
        
        Copy-Item -Path $sourceFile -Destination $targetPath -Force -ErrorAction Stop
        Write-Output "SUCCESS: $server"
    }
    catch {
        Write-Output "ERROR: $server - $($_.Exception.Message)"
    }
}

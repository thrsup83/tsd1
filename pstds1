# Configuration
$TargetServer = "XXXXXXXX"
$FilePath     = "D:\tst\tst1.txt"
$BackupDir    = "C:\temp\chgs\$($TargetServer)_bkp"
$Timestamp    = Get-Date -Format "yyyyMMdd_HHmm"
$OutputFile   = "ACL_File_Bkp_$Timestamp.txt"

$ScriptBlock = {
    param($FilePath, $BackupDir, $OutputFile)

    try {
        # Create bkp folder
        if (-not (Test-Path $BackupDir)) {
            New-Item -Path $BackupDir -ItemType Directory -Force | Out-Null
        }

        # Split path to handle the file specifically
        $Parent = Split-Path $FilePath
        $FileName = Split-Path $FilePath -Leaf
        $TargetBkp = Join-Path $BackupDir $OutputFile

        # Run icacls on the file only
        Push-Location $Parent
        & icacls $FileName /save $TargetBkp
        Pop-Location

        if ($LASTEXITCODE -eq 0) {
            Write-Host "Success: Backup for $FileName created at $TargetBkp" -ForegroundColor Green
        }
    }
    catch {
        Write-Error "Error: $($_.Exception.Message)"
    }
}

# Remote execution
Write-Host "Starting backup on $TargetServer..." -ForegroundColor Yellow
Invoke-Command -ComputerName $TargetServer -ScriptBlock $ScriptBlock -ArgumentList $FilePath, $BackupDir, $OutputFile

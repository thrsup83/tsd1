$regPath = "HKLM:\SOFTWARE\YYYYYLabs\YYYYYAgent"
$progFiles = "C:\Program Files\YYYYYOne"

if (Test-Path $regPath) {
    $version = (Get-ItemProperty -Path $regPath -Name "Version" -ErrorAction SilentlyContinue).Version
    
    if (Test-Path $progFiles) {
        Write-Output "OK - $version"
    } else {
        Write-Output "fail - Folder missing"
    }
} else {
    Write-Output "fail - Registry missing"
}

$timestamp = Get-Date -Format "yyyyMMdd_HHmm"
$installerDir = "C:\temp\YYYYYYYYY_installer"
$msiPath = Join-Path $installerDir "YYYYYYYYY.msi"
$logPath = Join-Path $installerDir "YYYYYYYYYinstall_$timestamp.log"
$token = "XXXXX"

if (-not (Test-Path $msiPath)) {
    Write-Output "installernotfound"
    exit 1
}

$args = "/i `"$msiPath`" /qn SITE_TOKEN=$token /norestart /L*V `"$logPath`""
$process = Start-Process -FilePath "msiexec.exe" -ArgumentList $args -Wait -PassThru

$regPath = "HKLM:\SOFTWARE\YYYYYYYYY\YYYYYYYYY"
$progFiles = "C:\Program Files\YYYYYYYYY"

if (Test-Path $regPath) {
    $version = (Get-ItemProperty -Path $regPath -Name "Version" -ErrorAction SilentlyContinue).Version
    $appFolder = Get-ChildItem -Path $progFiles -Filter "YYYYYYYYY*" -Directory | Select-Object -First 1
    
    if ($appFolder) {
        $bin1 = Test-Path (Join-Path $appFolder.FullName "YYYYYYYYYAgent.exe")
        $bin2 = Test-Path (Join-Path $appFolder.FullName "YYYYYYYYYctl.exe")
        
        if ($bin1 -and $bin2) {
            Write-Output "OK - $version"
        } else {
            Write-Output "fail"
        }
    } else {
        Write-Output "fail"
    }
} else {
    Write-Output "fail"
}

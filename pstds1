$r = Get-ItemProperty -Path "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\Memory Management" -ErrorAction SilentlyContinue
$m = if ($null -ne $r.FeatureSettingsOverrideMask) { $r.FeatureSettingsOverrideMask } else { "NULL" }
$o = if ($null -ne $r.FeatureSettingsOverride) { $r.FeatureSettingsOverride } else { "NULL" }
Write-Output "mask = $m - over = $o"
